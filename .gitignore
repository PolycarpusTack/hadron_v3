# ==============================================
# Hadron v3 - Project .gitignore
# ==============================================

# ----------------------------------------------
# Archive directories (obsolete/unused files)
# ----------------------------------------------
.archive/
**/archive/
**/.archive/

# ----------------------------------------------
# Build artifacts
# ----------------------------------------------
*.exe
*.msi
*.dmg
*.AppImage
*.deb
*.rpm
dist/
build/
target/
out/

# ----------------------------------------------
# Node.js
# ----------------------------------------------
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn/cache
.pnp.*

# ----------------------------------------------
# Python
# ----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# ----------------------------------------------
# Rust/Tauri
# ----------------------------------------------
**/target/
**/*.rs.bk
Cargo.lock

# ----------------------------------------------
# IDE and Editor
# ----------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.code-workspace

# ----------------------------------------------
# Operating System
# ----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------------
# Logs
# ----------------------------------------------
logs/
*.log

# ----------------------------------------------
# Database
# ----------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ----------------------------------------------
# Environment and Secrets
# ----------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ----------------------------------------------
# Testing
# ----------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# ----------------------------------------------
# Temporary and Cache
# ----------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.cache
.cache/
tmp/
temp/

# ----------------------------------------------
# Obsolete planning documents at root
# ----------------------------------------------
RELEASE-v1.1.0.md

# ----------------------------------------------
# Stray HTML mockups
# ----------------------------------------------
hadron-desktop/WHATS_ON_Crash_Analyzer_Enhanced*.html

# ----------------------------------------------
# Git Worktrees
# ----------------------------------------------
.worktrees/

# ----------------------------------------------
# Tool caches and MCP artifacts
# ----------------------------------------------
.codex
.playwright-mcp/

# ----------------------------------------------
# Docker volumes and data
# ----------------------------------------------
pgdata/
hadron-web/pgdata/
