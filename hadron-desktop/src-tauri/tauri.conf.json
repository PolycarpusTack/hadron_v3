{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hadron",
  "version": "4.1.0",
  "identifier": "com.hadron.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hadron - AI Support Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "widget",
        "url": "widget.html",
        "title": "Hadron Quick",
        "width": 400,
        "height": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self'; script-src 'self'",
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Capability for the main window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:default",
            "store:default",
            "updater:default",
            "process:default",
            "notification:default",
            "window-state:default",
            "core:app:default",
            "core:window:default",
            "core:event:default"
          ]
        },
        {
          "identifier": "widget-capability",
          "description": "Capability for the widget window",
          "windows": ["widget"],
          "permissions": [
            "core:default",
            "core:window:default",
            "core:event:default",
            "global-shortcut:default",
            "clipboard-manager:default",
            "dialog:default",
            "store:default"
          ]
        }
      ]
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python/**/*"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2025 Hadron Team",
    "longDescription": "AI-powered support assistant with crash analysis, knowledge base search, and intelligent debugging",
    "shortDescription": "AI Support Assistant"
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/PolycarpusTack/hadron_v3/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
