# Database
DATABASE_URL=postgres://hadron:hadron_dev@localhost:5432/hadron
DB_PASSWORD=hadron_dev

# Auth: "dev" bypasses Azure AD with a pre-seeded admin user
AUTH_MODE=dev

# Azure AD (required when AUTH_MODE is not "dev")
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# AI Provider (optional — configure in Settings UI instead)
OPENAI_API_KEY=

# Server
PORT=8080
RUST_LOG=info
